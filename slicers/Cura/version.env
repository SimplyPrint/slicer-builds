# Cura 5.13.0 is a coordinated release: CuraEngine consumes the definitions
# shipped by the matching Cura tag. Keep these references in lockstep.
CURA_VERSION=5.13.0
CURA_ENGINE_REPO=Ultimaker/CuraEngine
CURA_ENGINE_REF=636f9608621fd1d6c1b75ad2a969de53beabfbc6
CURA_RESOURCES_REPO=Ultimaker/Cura
CURA_RESOURCES_REF=1fb8a7610460e03ec62da950d1c173a249b23b59

# Conan's default profiles and public UltiMaker remotes are versioned too. The
# checked-in Conan lock pins the complete dependency graph's recipe revisions.
CURA_CONAN_CONFIG_REPO=Ultimaker/conan-config
CURA_CONAN_CONFIG_REF=bba7984a7363709f239fc13a3a3e0b02ecc2488b
CURA_CONAN_VERSION=2.15.1
