             glfwSetErrorCallback(glfw_callback);
+#if (defined(__linux__) || defined(__LINUX__)) && defined(GLFW_PLATFORM) && defined(GLFW_PLATFORM_X11)
+            // GLFW 3.4 may select Wayland when both Weston and Xwayland are
