+static void log_linux_cli_diagnostics(int argc, char **argv)
+{
+    boost::system::error_code ec;
+    boost::filesystem::path cwd = boost::filesystem::current_path(ec);
+
+    BOOST_LOG_TRIVIAL(error) << "main diagnostics: cwd=" << (ec ? std::string("<error: ") + ec.message() + ">" : cwd.string())
+                             << ", temp_dir=" << wxFileName::GetTempDir().ToStdString()
+                             << ", data_dir=" << Slic3r::data_dir()
+                             << ", resources_dir=" << Slic3r::resources_dir()
+                             << ", argc=" << argc;
+
+    for (int i = 0; i < argc; ++i)
+        BOOST_LOG_TRIVIAL(error) << "main argv[" << i << "]=" << (argv[i] ? argv[i] : "<null>");
+
+    boost::log::core::get()->flush();
+}
+
+static int run_cli_with_diagnostics(int argc, char **argv)
+{
+    try {
+        log_linux_cli_diagnostics(argc, argv);
+    } catch (const std::exception &ex) {
+        boost::nowide::cerr << "Failed to log startup diagnostics: " << ex.what() << std::endl;
+    } catch (...) {
+        boost::nowide::cerr << "Failed to log startup diagnostics" << std::endl;
+    }
+
+    try {
+        return CLI().run(argc, argv);
+    } catch (const boost::filesystem::filesystem_error &ex) {
+        BOOST_LOG_TRIVIAL(error) << "Uncaught boost::filesystem::filesystem_error: " << ex.what()
+                                 << ", code=" << ex.code().value()
+                                 << ", category=" << ex.code().category().name()
+                                 << ", message=" << ex.code().message()
+                                 << ", path1=" << ex.path1().string()
+                                 << ", path2=" << ex.path2().string();
+        boost::nowide::cerr << "Uncaught boost::filesystem::filesystem_error: " << ex.what() << std::endl;
+        boost::log::core::get()->flush();
+        return 1;
+    } catch (const std::exception &ex) {
+        BOOST_LOG_TRIVIAL(error) << "Uncaught std::exception: " << ex.what();
+        boost::nowide::cerr << "Uncaught std::exception: " << ex.what() << std::endl;
+        boost::log::core::get()->flush();
+        return 1;
+    } catch (...) {
+        BOOST_LOG_TRIVIAL(error) << "Uncaught non-standard exception";
+        boost::nowide::cerr << "Uncaught non-standard exception" << std::endl;
+        boost::log::core::get()->flush();
+        return 1;
+    }
+}
