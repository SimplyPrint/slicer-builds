+void SettingsFactory::dump_settings_subsets_to_json()
+{
+    auto program_parent_dir = boost::dll::program_location().parent_path();
+
+    auto object_options = get_options(false);
+    auto object_categories = get_all_visible_options(false);
+    write_subset_json(program_parent_dir / "object_settings.json", object_options, object_categories);
+
+    auto part_options = get_options(true);
+    auto part_categories = get_all_visible_options(true);
+    write_subset_json(program_parent_dir / "part_settings.json", part_options, part_categories);
+
+    auto height_range_options = get_options(true);
+    height_range_options.push_back("layer_height");
+    auto height_range_categories = get_all_visible_options(true);
+    auto quality_it = height_range_categories.find(L("Quality"));
+    if (quality_it == height_range_categories.end()) {
+        height_range_categories.emplace(L("Quality"), std::vector<SimpleSettingData>{{"layer_height", "", 0}});
+    } else {
+        quality_it->second.insert(quality_it->second.begin(), {"layer_height", "", 0});
+        auto sort_func = [](SimpleSettingData& setting1, SimpleSettingData& setting2) {
+            return setting1.priority < setting2.priority;
+        };
+        std::sort(quality_it->second.begin(), quality_it->second.end(), sort_func);
+    }
+
+    write_subset_json(program_parent_dir / "height_range_settings.json", height_range_options, height_range_categories);
+}
