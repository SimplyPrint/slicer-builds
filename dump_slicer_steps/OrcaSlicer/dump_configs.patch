+boost::property_tree::ptree build_categories_tree(const std::map<std::string, std::vector<SimpleSettingData>>& categories)
+{
+    using boost::property_tree::ptree;
+
+    ptree categories_tree;
+    for (const auto& category_entry : categories) {
+        ptree category_tree;
+        ptree settings_tree;
+        for (const auto& option : category_entry.second)
+            settings_tree.add("", option.name);
+        category_tree.add_child("Settings", settings_tree);
+        categories_tree.add_child(category_entry.first, category_tree);
+    }
+
+    return categories_tree;
+}
+
+void write_subset_json(
+    const boost::filesystem::path& output_path,
+    const std::vector<std::string>& eligible_keys,
+    const std::map<std::string, std::vector<SimpleSettingData>>& categories)
+{
+    using boost::property_tree::ptree;
+
+    ptree pt;
+    put_array(pt, "eligible_keys", eligible_keys);
+    pt.add_child("categoriesAndSettings", build_categories_tree(categories));
+    pt.add_child("icon_data", ptree());
+    write_json(output_path.string(), pt);
+}
